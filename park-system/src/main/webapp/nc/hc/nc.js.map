Image.url)+\')\',\'width\':getScaleNum(_backgroundImage.width),\'height\':getScaleNum(_backgroundImage.height)}"></div>\r\n            <div class="ds_seat_panel" ds-key="\'panel\'" ds-if="!_isSetttingIndex" ds-style="{\'width\':getScaleNum(_backgroundImage.width),\'height\':getScaleNum(_backgroundImage.height)}" ds-on-mousedown="panelMouseDownHandler">\r\n              <v-element ds-for="(item,$index) in $objectList">\r\n                <!--座席-->\r\n                <div ds-if="item.type==\'seat\'" ds-bind:sid="item.id" ds-bind:assist="item.isAssist?0:1" ds-bind:state="(item.state||\'0\')" ds-bind:seat-index="item.index" ds-on-contextmenu="[selectedObject(item,$event),contextMenuObjectHandler(item,$event)]" ds-on-dblclick="editObjectText(item,$event)" ds-key="item.id" class="ds_seat_object" ds-bind:type="item.type" ds-on-mousedown="[selectedObject(item,$event),moveObjectHandler(item,$event)]" ds-style="getItemCss(item,item)">\r\n                  <span ds-if="item.type==\'seat\'&&!item.editing" ds-html="item.text" ds-style="getTextCss(item)"></span>\r\n                  <div ds-else class="edit" ds-on-mousedown.stop ds-on-keydown="editObjectTextComplete(item,$event)" ds-on-blur="editObjectTextComplete(item,$event)" contenteditable="contenteditable" ds-html="item.text"></div>\r\n                </div>\r\n                <!--组-->\r\n                <div ds-if="item.type==\'group\'" ds-bind:sid="item.id" ds-on-contextmenu="[selectedObject(item,$event),contextMenuObjectHandler(item,$event)]" ds-on-dblclick="editObjectText(item,$event)" ds-key="item.id" class="ds_seat_object" ds-bind:type="item.type" ds-on-mousedown="[selectedObject(item,$event),moveObjectHandler(item,$event)]" ds-style="getItemCss(item)">\r\n                  <v-element ds-for="(child,$cindex) in item.child">\r\n                    <div ds-if="child.type==\'seat\'" ds-bind:sid="child.id" ds-bind:assist="item.isAssist?0:1" ds-bind:state="(child.state||\'0\')" ds-bind:seat-index="child.index" ds-key="child.id" class="ds_seat_object" ds-bind:type="child.type" ds-style="getItemCss(child,item.member)" ds-on-dblclick="editObjectText(child,$event)">\r\n                      <span ds-if="child.type==\'seat\'&&!child.editing" ds-html="child.text" ds-style="getTextCss(child)"></span>\r\n                      <div ds-else class="edit" ds-on-mousedown.stop ds-on-keydown="editObjectTextComplete(child,$event)" ds-on-blur="editObjectTextComplete(child,$event)" contenteditable="contenteditable" ds-html="child.text"></div>\r\n                    </div>\r\n                  </v-element>\r\n                </div>\r\n                <!--辅助对象 start-->\r\n                <div ds-if="item.type==\'rect\'" ds-bind:sid="item.id" state="0" ds-bind:assist="item.isAssist?0:1" ds-on-dblclick="editObjectText(item,$event)" ds-key="item.id" class="ds_seat_object" ds-bind:type="item.type" ds-on-mousedown="[selectedObject(item,$event),moveObjectHandler(item,$event)]" ds-style="getItemCss(item,item)">\r\n                  <span ds-if="!item.editing" ds-html="item.text"></span>\r\n                  <div ds-else class="edit" ds-on-mousedown.stop ds-on-keydown="editObjectTextComplete(item,$event)" ds-on-blur="editObjectTextComplete(item,$event)" contenteditable="contenteditable" ds-html="item.text"></div>\r\n                </div>\r\n\r\n                <div ds-if="item.type==\'text\'" ds-bind:sid="item.id" state="0" ds-bind:assist="item.isAssist?0:1" ds-on-dblclick="editObjectText(item,$event)" ds-key="item.id" class="ds_seat_object" ds-bind:type="item.type" ds-on-mousedown="[selectedObject(item,$event),moveObjectHandler(item,$event)]" ds-style="getItemCss(item)">\r\n                  <span ds-if="!item.editing" ds-html="item.text"></span>\r\n                  <div ds-else class="edit" ds-on-mousedown.stop ds-on-keydown="editObjectTextComplete(item,$event)" ds-on-blur="editObjectTextComplete(item,$event)" contenteditable="contenteditable" ds-html="item.text"></div>\r\n                </div>\r\n                <!--辅助对象 end-->\r\n              </v-element>\r\n              <!--选中后的编辑框-->\r\n              <div ds-key="selectedRect" ds-if="_selectedRect.show" class="ds_select_rect" ds-style="{\'transform\':\'rotate(\' +_selectedRect.angle + \'deg)\',\'top\':getScaleNum(_selectedRect.top),\'left\':getScaleNum(_selectedRect.left),\'width\':getScaleNum(_selectedRect.width),\'height\':getScaleNum(_selectedRect.height)}">\r\n                <div class="cp" ds-on-mousedown="rotateObjectHandler($event)"></div>\r\n                <div class="cpline"></div>\r\n                <div class="t" pos="t" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                <div class="l" pos="l" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                <div class="r" pos="r" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                <div class="b" pos="b" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                <div class="tl" pos="tl" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                <div class="tr" pos="tr" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                <div class="bl" pos="bl" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                <div class="br" pos="br" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                <div class="info">宽:{{Math.ceil(_selectedRect.width)}};高:{{Math.ceil(_selectedRect.height)}};角度:{{Math.ceil(_selectedRect.angle)}}</div>\r\n              </div>\r\n              <!--框选-->\r\n              <div class="ds_range_selection" ds-key="rangeselection" ds-if="_rangeSelectionRect.show" ds-style="{\'width\':getScaleNum(_rangeSelectionRect.width),\'height\':getScaleNum(_rangeSelectionRect.height),\'top\':getScaleNum(_rangeSelectionRect.top),\'left\':getScaleNum(_rangeSelectionRect.left)}"></div>\r\n              <!--水平对齐标线-->\r\n              <div style="position:absolute;border-style:none;border-top:1px dotted #6EB1EB;width:100%;height:1px" ds-style="{\'top\':_assist.v.top}" ds-if="_moving&&_assist.v.show"></div>\r\n              <!--竖直对齐标线-->\r\n              <div style="position:absolute;border-left:1px dotted #6EB1EB;height:100%;" ds-style="{\'left\':_assist.h.left}" ds-if="_moving&&_assist.h.show"></div>\r\n              <!--右键菜单-->\r\n              <div class="layui-nav ds-menu" ds-if="_contextMenuData.show" style="position:absolute;width:0px;height:0px;z-index:9999" ds-style="{\'top\':getScaleNum(_contextMenuData.top),\'left\':getScaleNum(_contextMenuData.left)}">\r\n                <dl class="layui-nav-child layui-anim layui-anim-upbit" style="width:auto;min-width:0px;left:0px;top:0px;display:block">\r\n                  <dd ds-for="(item,$index) in _contextMenuData.items">\r\n                    <a style="padding:0px 20px;display:block;cursor:pointer" ds-on-mousedown.stop.prevent ds-on-click="contextMenuClickHandler(item,$event)">{{item.text}}</a>\r\n                  </dd>\r\n                </dl>\r\n              </div>\r\n            </div>\r\n            <!--设置序号后的代理-->\r\n            <div ds-key="settingindex" ds-if="_isSetttingIndex" style="opacity:.5;position:absolute;background-color:#000;z-index:999" ds-style="{\'width\':getScaleNum(_backgroundImage.width),\'height\':getScaleNum(_backgroundImage.height)}">\r\n              <v-element ds-for="(item,$index) in $objectList">\r\n                <!--座席-->\r\n                <div ds-if="item.type==\'seat\'" ds-bind:sid="item.id" ds-bind:assist="item.isAssist?0:1" ds-bind:state="(item.state||\'0\')" ds-bind:seat-index="item.index" ds-key="item.id" class="ds_seat_object" ds-bind:type="item.type" ds-style="getItemCss(item,item)" ds-on-click.stop="clickSettingIndex(item)">\r\n                  <span>{{item.index}}</span>\r\n                </div>\r\n                <!--组-->\r\n                <div ds-if="item.type==\'group\'" ds-bind:sid="item.id" ds-key="item.id" class="ds_seat_object" ds-bind:type="item.type" ds-style="getItemCss(item)">\r\n                  <v-element ds-for="(child,$cindex) in item.child">\r\n                    <div ds-if="child.type==\'seat\'" ds-bind:sid="child.id" ds-bind:assist="item.isAssist?0:1" ds-bind:state="(child.state||\'0\')" ds-bind:seat-index="child.index" ds-key="child.id" class="ds_seat_object" ds-bind:type="child.type" ds-style="getItemCss(child,item.member)" ds-on-click.stop="clickSettingIndex(child)">\r\n                      <span>{{child.index}}</span>\r\n                    </div>\r\n                  </v-element>\r\n                </div>\r\n              </v-element>\r\n            </div>\r\n          </div>\r\n\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class="desginer_left" ds-style="{\'margin-top\': $headHeight, \'width\': $leftWidth }">\r\n      <div class="ds_tools" style="margin:0px;">\r\n        <div lay-accordion lay-filter="seat-object" class="layui-collapse">\r\n          <div class="layui-colla-item" ds-for="(item,$index) in getObject()">\r\n            <div class="layui-colla-title">{{item.title}}</div>\r\n            <div class="layui-colla-content layui-show">\r\n              <div ds-for="(obj,$index) in item.items" class="ds_tool_item" ds-on-mousedown="initToolsDrag(obj,$event)">{{obj.text}}</div>\r\n              <div style="clear:both;"></div>\r\n            </div>\r\n          </div>\r\n          <div class="layui-colla-item">\r\n            <div class="layui-colla-title">\r\n              自定义对象\r\n              <i style="float:right" class="iconfont icon-hao ds_icon4" title="增加" ds-on-click.stop="addCustomerObject"></i>\r\n            </div>\r\n            <div class="layui-colla-content layui-show">\r\n              <div ds-for="(obj,$index) in _customerList" class="ds_tool_item" ds-on-dblclick="editCutomerObject(obj,$event)" ds-on-mousedown="initToolsDrag(obj,$event)">{{obj.text}}</div>\r\n              <div style="clear:both;"></div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class="desginer_props" ds-style="{\'margin-top\': $headHeight}">\r\n      <dl>\r\n        <v-element ds-for="(item,$index) in _props" ds-if="item.has(item,currSelected)">\r\n          <dd ds-if="item.clickType==\'showWindow\'" ds-bind:title="item.text" ds-key="item.text" ds-on-click="propWindowShow(item)">\r\n            <i class="iconfont" ds-class="item.icon"></i>\r\n            <div class="propswindow" ds-if="item.show&&currSelected.id">\r\n              <div class="propswindow_title">\r\n                {{item.text}}\r\n                <i class="iconfont icon-right" ds-on-click.stop="propWindowClose(item)"></i>\r\n              </div>\r\n              <div class="propswindow_content">\r\n                <v-element ds-if="item.type==\'size\'">\r\n                  <!--度量-->\r\n                  <div class="layui-form layui-fluid" style="width:400px">\r\n                    <div class="layui-row">\r\n                      <div class="layui-col-xs6">\r\n                        <div class="layui-form-item">\r\n                          <label class="layui-form-label">X</label>\r\n                          <div class="layui-input-inline">\r\n                            <input type="text" name="left" autocomplete="off" ds-bind:value="currSelected.left" class="layui-input" ds-on-change="propValueChange(\'left\',$event)">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div class="layui-col-xs6">\r\n                        <div class="layui-form-item">\r\n                          <label class="layui-form-label">Y</label>\r\n                          <div class="layui-input-inline">\r\n                            <input type="text" name="top" autocomplete="off" ds-bind:value="currSelected.top" class="layui-input" ds-on-change="propValueChange(\'top\',$event)">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                    <div class="layui-row">\r\n                      <div class="layui-col-xs6">\r\n                        <div class="layui-form-item">\r\n                          <label class="layui-form-label">宽</label>\r\n                          <div class="layui-input-inline">\r\n                            <input type="text" name="width" autocomplete="off" ds-bind:value="currSelected.width" class="layui-input" ds-on-change="propValueChange(\'width\',$event)">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div class="layui-col-xs6">\r\n                        <div class="layui-form-item">\r\n                          <label class="layui-form-label">高</label>\r\n                          <div class="layui-input-inline">\r\n                            <input type="text" name="height" autocomplete="off" ds-bind:value="currSelected.height" class="layui-input" ds-on-change="propValueChange(\'height\',$event)">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                    <div class="layui-row">\r\n                      <div class="layui-col-xs6">\r\n                        <div class="layui-form-item">\r\n                          <label class="layui-form-label">角度</label>\r\n                          <div class="layui-input-inline">\r\n                            <input type="text" name="left" autocomplete="off" ds-bind:value="currSelected.angle" class="layui-input" ds-on-change="propValueChange(\'angle\',$event)">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                    <div class="layui-row" ds-if="currSelected.type==\'group\'">\r\n                      <div class="layui-row">\r\n                        <div class="layui-col-xs6">\r\n                          <div class="layui-form-item">\r\n                            <label class="layui-form-label">成员宽</label>\r\n                            <div class="layui-input-inline">\r\n                              <input type="text" name="width" autocomplete="off" ds-bind:value="currSelected.member.width" class="layui-input" ds-on-change="propValueChange(\'member.width\',$event)">\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                        <div class="layui-col-xs6">\r\n                          <div class="layui-form-item">\r\n                            <label class="layui-form-label">成员高</label>\r\n                            <div class="layui-input-inline">\r\n                              <input type="text" name="height" autocomplete="off" ds-bind:value="currSelected.member.height" class="layui-input" ds-on-change="propValueChange(\'member.height\',$event)">\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                        <div class="layui-col-xs6">\r\n                          <div class="layui-form-item">\r\n                            <label class="layui-form-label">行间距</label>\r\n                            <div class="layui-input-inline">\r\n                              <input type="text" name="width" autocomplete="off" ds-bind:value="currSelected.rowSplit" class="layui-input" ds-on-change="propValueChange(\'rowSplit\',$event)">\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                        <div class="layui-col-xs6">\r\n                          <div class="layui-form-item">\r\n                            <label class="layui-form-label">列间距</label>\r\n                            <div class="layui-input-inline">\r\n                              <input type="text" name="width" autocomplete="off" ds-bind:value="currSelected.colSplit" class="layui-input" ds-on-change="propValueChange(\'colSplit\',$event)">\r\n                            </div>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </v-element>\r\n\r\n                <!--文字-->\r\n                <v-element ds-if="item.type==\'text\'">\r\n                  <!--座席属性内容-->\r\n                  <div class="layui-form layui-fluid" ds-if="currSelected.type==\'seat\'" style="width:400px;min-height:400px" ds-key="\'s\'">\r\n                    <div class="layui-row">\r\n                      <div class="layui-col-xs6" ds-for="p in getObjectAttrs(currSelected)" :key="p.key">\r\n                        <div class="layui-form-item">\r\n                          <label class="layui-form-label">{{p.text}}</label>\r\n                          <div class="layui-input-block">\r\n                            <input ds-if="p.type==\'input\'" type="text" ds-bind:name="\'attr-\'+p.key" autocomplete="off" ds-bind:value="getObjectAttrValue(currSelected,p.key)" class="layui-input" ds-on-change="propValueChange(\'attrs.\'+p.key,$event)">\r\n                            <select ds-if="p.type==\'select\'" ds-bind:name="\'attr-\'+p.key" ds-on-change="propValueChange(\'attrs.\'+p.key,$event)">\r\n                              <option ds-for="op in p.options" ds-bind:value="op.value" ds-bind:selected="getObjectAttrValue(currSelected,p.key)==op.value">{{op.text}}</option>\r\n                            </select>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                    <div class="layui-row">\r\n                      <div class="layui-col-xs6">\r\n                        <div class="layui-form-item">\r\n                          <label class="layui-form-label">序号</label>\r\n                          <div class="layui-input-block">\r\n                            <input type="text" name="left" autocomplete="off" ds-bind:value="currSelected.index" class="layui-input" ds-on-change="propValueChange(\'index\',$event)">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div class="layui-col-xs6">\r\n                        <div class="layui-form-item">\r\n                          <label class="layui-form-label">文本</label>\r\n                          <div class="layui-input-block">\r\n                            <input type="text" name="top" autocomplete="off" ds-bind:value="currSelected.text" class="layui-input" ds-on-change="propValueChange(\'text\',$event)">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                  <!--组属性内容-->\r\n                  <div class="layui-form layui-fluid" ds-if="currSelected.type==\'group\'" style="width:500px" ds-key="\'g\'">\r\n                    <div class="layui-row">\r\n                      <div class="layui-col-xs6" ds-for="p in getObjectAttrs(currSelected)" :key="p.key">\r\n                        <div class="layui-form-item">\r\n                          <label class="layui-form-label">{{p.text}}</label>\r\n                          <div class="layui-input-block">\r\n                            <input ds-if="p.type==\'input\'" type="text" ds-bind:name="\'attr-\'+p.key" autocomplete="off" ds-bind:value="getObjectAttrValue(currSelected,p.key)" class="layui-input" ds-on-change="propValueChange(\'attrs.\'+p.key,$event)">\r\n                            <select ds-if="p.type==\'select\'" ds-bind:name="\'attr-\'+p.key" ds-on-change="propValueChange(\'attrs.\'+p.key,$event)">\r\n                              <option ds-for="op in p.options" ds-bind:value="op.value" ds-bind:selected="getObjectAttrValue(currSelected,p.key)==op.value">{{op.text}}</option>\r\n                            </select>\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                    <div class="layui-row" ds-for="(child,$index) in currSelected.child">\r\n                      <div class="layui-col-xs12" style="text-align:left;font-weight:600;">\r\n                        {{child.rowIndex}}行{{child.colIndex}}列:\r\n                      </div>\r\n                      <div class="layui-col-xs6">\r\n                        <div class="layui-form-item">\r\n                          <label class="layui-form-label">序号</label>\r\n                          <div class="layui-input-block">\r\n                            <input type="text" name="left" autocomplete="off" ds-bind:value="child.index" class="layui-input" ds-on-change="propValueChange(\'index\',$event,child)">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                      <div class="layui-col-xs6">\r\n                        <div class="layui-form-item" style="width:100%">\r\n                          <label class="layui-form-label">文本</label>\r\n                          <div class="layui-input-block">\r\n                            <input type="text" name="top" autocomplete="off" ds-bind:value="child.text" class="layui-input" ds-on-change="propValueChange(\'text\',$event,child)">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                  <!--辅助矩形属性内容-->\r\n                  <div class="layui-form layui-fluid" ds-if="currSelected.type==\'rect\'||currSelected.type==\'text\'" style="width:300px" ds-key="\'r\'">\r\n                    <div class="layui-row">\r\n                      <div class="layui-col-xs12">\r\n                        <div class="layui-form-item">\r\n                          <label class="layui-form-label">文本</label>\r\n                          <div class="layui-input-block">\r\n                            <input type="text" name="top" autocomplete="off" ds-bind:value="currSelected.text" class="layui-input" ds-on-change="propValueChange(\'text\',$event)">\r\n                          </div>\r\n                        </div>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </v-element>\r\n                <!--图标上传-->\r\n                <v-element ds-if="item.type==\'bgImg\'">\r\n                  <div class="layui-form layui-fluid">\r\n                    <!--座位-->\r\n                    <div class="layui-row" ds-if="currSelected.type==\'group\'||currSelected.type==\'seat\'" ds-key="\'1\'" style="width:400px">\r\n                      <div ds-for="(item, $index) in $uploadImgBox" class="layui-col-xs4">\r\n                        <a class="domeImg" ds-bind:id="\'img_\'+ item.key" ds-on-click="uploadSeatBgSrc(item.key)" ds-bind:state="item.key" style="display:block;width:100px;height:100px;border:1px solid #E5E5E5;margin:auto">\r\n                          <img ds-if="getSelectedObjectBgImg(item.key)" ds-bind:src="getSelectedObjectBgImg(item.key)" style="width:100%;height:auto">\r\n                        </a>\r\n                        <div>{{item.value}}</div>\r\n                      </div>\r\n\r\n                      <!--<div class="layui-col-xs4">\r\n                        <a class="domeImg" ds-bind:id="\'img_0\'" ds-on-click="uploadSeatBgSrc(0)" state="0" style="display:block;width:100px;height:100px;border:1px solid #E5E5E5;margin:auto">\r\n                          <img ds-if="getSelectedObjectBgImg(0)" ds-bind:src="getSelectedObjectBgImg(0)" style="width:100%;height:auto" />\r\n                        </a>\r\n                        <div>正常</div>\r\n                      </div>\r\n                      <div class="layui-col-xs4">\r\n                        <a class="domeImg" ds-bind:id="\'img_1\'" ds-on-click="uploadSeatBgSrc(1)" state="1" style="display:block;width:100px;height:100px;border:1px solid #E5E5E5;margin:auto">\r\n                          <img ds-if="getSelectedObjectBgImg(1)" ds-bind:src="getSelectedObjectBgImg(1)" style="width:100%;height:auto" />\r\n                        </a>\r\n                        <div>已排</div>\r\n                      </div>\r\n                      <div class="layui-col-xs4">\r\n                        <a class="domeImg" ds-bind:id="\'img_-1\'" ds-on-click="uploadSeatBgSrc(-1)" state="-1" style="display:block;width:100px;height:100px;border:1px solid #E5E5E5;margin:auto">\r\n                          <img ds-if="getSelectedObjectBgImg(-1)" ds-bind:src="getSelectedObjectBgImg(-1)" style="width:100%;height:auto" />\r\n                        </a>\r\n                        <div>禁用</div>\r\n                      </div>\r\n                      <div class="layui-col-xs4">\r\n                        <a class="domeImg" ds-bind:id="\'img_-2\'" ds-on-click="uploadSeatBgSrc(-2)" state="-2" style="display:block;width:100px;height:100px;border:1px solid #E5E5E5;margin:auto">\r\n                          <img ds-if="getSelectedObjectBgImg(-2)" ds-bind:src="getSelectedObjectBgImg(-2)" style="width:100%;height:auto" />\r\n                        </a>\r\n                        <div>锁定</div>\r\n                      </div>-->\r\n                    </div>\r\n                    <!--辅助对象-->\r\n                    <div class="layui-row" ds-if="currSelected.type==\'rect\'" ds-key="\'2\'" style="width:200px">\r\n                      <div class="layui-col-xs12" style="text-align:center;">\r\n                        <a class="domeImg" ds-bind:id="\'img_0\'" ds-on-click="uploadSeatBgSrc(0)" state="0" style="display:block;width:100px;height:100px;border:1px solid #E5E5E5;margin:auto">\r\n                          <img ds-if="getSelectedObjectBgImg(0)" ds-bind:src="getSelectedObjectBgImg(0)" style="width:100%;height:auto">\r\n                        </a>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </v-element>\r\n              </div>\r\n            </div>\r\n          </dd>\r\n        </v-element>\r\n      </dl>\r\n    </div>\r\n\r\n  </div>\r\n  <div id="customerObject" class="layui-form layui-fluid" style="padding:10px" ds-if="_customerDialog.show">\r\n    <div class="layui-row">\r\n      <div class="layui-col-xs12">\r\n        <div class="layui-form-item">\r\n          <label class="layui-form-label">名称</label>\r\n          <div class="layui-input-block">\r\n            <input type="text" name="name" autocomplete="off" class="layui-input" ds-bind:value="_customerDialog.obj.name">\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class="layui-row">\r\n      <div class="layui-col-xs12">\r\n        <div class="layui-form-item">\r\n          <label class="layui-form-label">来源</label>\r\n          <div class="layui-input-block">\r\n            <select name="source">\r\n              <option ds-for="op in getObject()[0].items" ds-bind:value="op.oid" ds-bind:selected="_customerDialog.obj.source.value==op.oid">{{op.text}}</option>\r\n            </select>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class="layui-row">\r\n      <div class="layui-col-xs12">\r\n        <div class="layui-form-item">\r\n          <label class="layui-form-label">状态图</label>\r\n          <div class="layui-input-block">\r\n            <div ds-for="(item, $index) in $uploadImgBox" class="layui-col-xs4">\r\n              <a class="domeImg" ds-bind:id="\'cimg_\'+ item.key" ds-on-click="updateCustomerSeatBgSrc(item.key)" ds-bind:state="item.key" style="display:block;width:100px;height:100px;border:1px solid #E5E5E5;margin:auto">\r\n                <img ds-if="getCustomerSeatBgSrc(item.key)" ds-bind:src="getCustomerSeatBgSrc(item.key)" style="width:100%;height:auto">\r\n              </a>\r\n              <div style="text-align: center;">{{item.value}}</div>\r\n            </div>\r\n           <!-- <div class="layui-col-xs4">\r\n              <a class="domeImg" ds-bind:id="\'cimg_0\'" ds-on-click="updateCustomerSeatBgSrc(0)" state="0" style="display:block;width:100px;height:100px;border:1px solid #E5E5E5;margin:auto">\r\n                <img ds-if="getCustomerSeatBgSrc(0)" ds-bind:src="getCustomerSeatBgSrc(0)" style="width:100%;height:auto" />\r\n              </a>\r\n              <div style="text-align: center;">正常</div>\r\n            </div>\r\n            <div class="layui-col-xs4">\r\n              <a class="domeImg" ds-bind:id="\'cimg_1\'" ds-on-click="updateCustomerSeatBgSrc(1)" state="1" style="display:block;width:100px;height:100px;border:1px solid #E5E5E5;margin:auto">\r\n                <img ds-if="getCustomerSeatBgSrc(1)" ds-bind:src="getCustomerSeatBgSrc(1)" style="width:100%;height:auto" />\r\n              </a>\r\n              <div style="text-align: center;">已排</div>\r\n            </div>\r\n            <div class="layui-col-xs4">\r\n              <a class="domeImg" ds-bind:id="\'cimg_-1\'" ds-on-click="updateCustomerSeatBgSrc(-1)" state="-1" style="display:block;width:100px;height:100px;border:1px solid #E5E5E5;margin:auto">\r\n                <img ds-if="getCustomerSeatBgSrc(-1)" ds-bind:src="getCustomerSeatBgSrc(-1)" style="width:100%;height:auto" />\r\n              </a>\r\n              <div style="text-align: center;">禁用</div>\r\n            </div>\r\n            <div class="layui-col-xs4">\r\n              <a class="domeImg" ds-bind:id="\'cimg_-2\'" ds-on-click="updateCustomerSeatBgSrc(-2)" state="-2" style="display:block;width:100px;height:100px;border:1px solid #E5E5E5;margin:auto">\r\n                <img ds-if="getCustomerSeatBgSrc(-2)" ds-bind:src="getCustomerSeatBgSrc(-2)" style="width:100%;height:auto" />\r\n              </a>\r\n              <div style="text-align: center;">锁定</div>\r\n            </div>-->\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n  </div>\r\n\r\n</div>');
            __line = 480;

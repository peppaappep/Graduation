[

   {
      "name": "基础属性",
      "attributes": [{
            "text": "组件标识",
            "bindControlAttr": "caption",
            "showType": "text"
         },
         {
            "text": "标题",
            "showType": "text",
            "bindControlAttr": "label"
         },
         {
            "text": "搜索框提示文字",
            "showType": "text",
            "bindControlAttr": "searchPlaceholder"
         },
         {
            "text": "数据列设置",
            "showType": "dialog",
            "bindControlAttr": "columns",
            "changeExecFunction": "render",
            "config": {
               "title": "数据列设置",
               "url": "/dsfa/pd/views/datagridColumnEdit.html",
               "width": "1000px",
               "height": "600px",
               "buttonText": "设置"
            }
         },
         {
            "text": "查询条件设置",
            "showType": "dialog",
            "bindControlAttr": "$searchInfo",
            "config": {
               "title": "查询条件设置",
               "url": "/dsfa/pd/views/searchEdit.html",
               "width": "900px",
               "height": "700px",
               "buttonText": "设置"
            }
         },
         {
            "text": "高级查询设置",
            "showType": "dialog",
            "bindControlAttr": "$superSearchInfo",
            "changeExecFunction": "render",
            "config": {
               "title": "查询条件设置",
               "url": "/dsfa/pd/views/superSearchEdit.html",
               "width": "1300px",
               "height": "600px",
               "buttonText": "设置"
            }
         },
         {
            "text": "每页显示条数(逗号分隔)",
            "showType": "text",
            "bindControlAttr": "$limitsText",
            "changeExecFunction": "renderPagination"
         },
         {
            "text": "自定义排序",
            "showType": "dialog",
            "bindControlAttr": "$customerOrder",
            "changeExecFunction": "render",
            "config": {
               "title": "排序栏设置",
               "url": "/dsfa/pd/views/orderby.html?customer=1",
               "width": "1170px",
               "height": "600px",
               "buttonText": "设置"
            }
         },
         {
            "text": "默认排序",
            "showType": "dialog",
            "bindControlAttr": "$defaultOrder",
            "config": {
               "title": "排序栏设置",
               "url": "/dsfa/pd/views/orderby.html?customer=0",
               "width": "1170px",
               "height": "600px",
               "buttonText": "设置"
            }
         },
         {
            "text": "按钮栏设置",
            "showType": "dialog",
            "bindControlAttr": "$buttonBar",
            "changeExecFunction": "renderButtonBar",
            "config": {
               "title": "按钮栏设置",
               "url": "/dsfa/pd/views/buttonsEdit.html",
               "width": "1400px",
               "height": "600px",
               "buttonText": "设置"
            }
         },
         {
            "text": "数据行按钮设置",
            "showType": "dialog",
            "bindControlAttr": "$rowbuttonBar",
            "changeExecFunction": "renderContext",
            "config": {
               "title": "数据行按钮设置",
               "url": "/dsfa/pd/views/buttonsEdit.html?dg=1",
               "width": "1500px",
               "height": "600px",
               "buttonText": "设置"
            }
         },
         {
            "text": "显示导出按钮",
            "showType": "boolean",
            "bindControlAttr": "showExport"
         },
         {
            "text": "系统按钮导出数据列",
            "showType": "dialog",
            "bindControlAttr": "$exportData",
            "changeExecFunction": "renderContext",
            "config": {
               "title": "导出数据列设置",
               "url": "/dsfa/pd/views/exportMetaData.html",
               "width": "1000px",
               "height": "600px",
               "buttonText": "设置"
            }
         },
         {
            "text": "显示面板头部",
            "showType": "boolean",
            "bindControlAttr": "showHead"
         },
         {
            "text": "显示标题",
            "showType": "boolean",
            "bindControlAttr": "showTitle"
         },
         {
            "text": "开启自定义获取数据",
            "showType": "boolean",
            "bindControlAttr": "customGetData",
            "hiddenKeyClass": "showPagination,0",
            "changeExecFunction": "changeShowPagination"
         },
         {
            "text": "显示分页(最多显示100条)",
            "showType": "boolean",
            "bindControlAttr": "showPagination",
            "class": "showPagination",
            "hidden": "customGetData==1",
            "hiddenKeyClass": "pageConfig"
         },
         {
            "text": "自定义分页排版(逗号分隔)",
            "showType": "text",
            "bindControlAttr": "pageLayout",
            "changeExecFunction": "renderPagination",
            "class": "pageConfig",
            "hidden": "showPagination==0"
         },
         {
            "text": "分页样式",
            "bindControlAttr": "pageStyle",
            "showType": "select",
            "changeExecFunction": "renderPaginationStyle",
            "dictionary": [{
                  "text": "默认",
                  "value": ""
               },
               {
                  "text": "块状",
                  "value": "block_page"
               }
            ],
            "class": "pageConfig",
            "hidden": "showPagination==0"
         },
         {
            "text": "是否仅单选",
            "showType": "boolean",
            "bindControlAttr": "$isSingleChecked",
            "changeExecFunction": "renderContext"
         },
         {
            "text": "自适应父容器(包含列表式此属性设置无效)",
            "showType": "boolean",
            "bindControlAttr": "$full",
            "changeExecFunction": "render"
         }
      ]
   },
   {
      "name": "高级属性",
      "attributes": [{
            "text": "数据展示方式",
            "showType": "checkbox",
            "bindControlAttr": "$showType",
            "changeExecFunction": "renderShowTypeButton",
            "dictionary": [{
               "text": "列表",
               "value": "list",
               "checked": true
            }, {
               "text": "卡片",
               "value": "card"
            }, {
               "text": "概述列表",
               "value": "img_list"
            }]
         },
         {
            "text": "卡片模式使用分页条",
            "showType": "boolean",
            "bindControlAttr": "cardShowPag",
            "changeExecFunction": "changeCardPag"
         },
         {
            "text": "浏览范围",
            "showType": "dataScopeEditor",
            "bindControlAttr": "$browseScope",
            "config": {
               "title": "范围设置",
               "width": "600px",
               "height": "600px",
               "buttonText": "设置"
            }
         },
         {
            "text": "卡片布局宽度",
            "bindControlAttr": "$cardWidth",
            "changeExecFunction": "resize",
            "showType": "text"
         },
         {
            "text": "概览列表项边框",
            "bindControlAttr": "$imgListBorder",
            "changeExecFunction": "render",
            "showType": "boolean"
         },
         {
            "text": "概览列表项圆角",
            "bindControlAttr": "$imgListBorderRadius",
            "changeExecFunction": "render",
            "showType": "boolean"
         }
      ]
   }
]
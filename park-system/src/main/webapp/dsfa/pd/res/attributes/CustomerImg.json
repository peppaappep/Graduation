[

    {
        "name": "基础属性",
        "attributes": [{
                "text": "组件标识",
                "bindControlAttr": "caption",
                "showType": "text"
            },
            {
                "text": "名称",
                "bindControlAttr": "label",
                "showType": "text",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "名称是否显示",
                "bindControlAttr": "showLabel",
                "showType": "boolean"
            },
            {
                "text": "是否只读",
                "showType": "boolean",
                "bindControlAttr": "readOnly"
            },
            {
                "text": "是否失效",
                "showType": "boolean",
                "bindControlAttr": "disabled",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否可见",
                "showType": "boolean",
                "bindControlAttr": "visible",
                "changeExecFunction": "renderContext"
            }
        ]
    },
    {
        "name": "高级属性",
        "attributes": [
            {
                "text": "必填标识",
                "bindControlAttr": "$required",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否裁剪照片",
                "showType": "boolean",
                "bindControlAttr": "$isCutPic",
                "hiddenKeyClass":"cutRatio",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "剪裁比例(如：16:9)",
                "showType": "text",
                "bindControlAttr": "$aspectRatio",
                "changeExecFunction": "renderContext",
                "class":"cutRatio",
                "hidden":"$isCutPic"
            }, 
            {
                "text": "上传图片大小限制",
                "bindControlAttr": "$maxFileSize",
                "showType": "text",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "图片选择",
                "bindControlAttr": "$backgroundSelectUrl",
                "showType": "text"
            },
            {
                "text": "图片选择框大小",
                "bindControlAttr": "$backgroundSelectSize",
                "showType": "text"
            },
            {
                "text": "图片选择框返回属性",
                "bindControlAttr": "$backgroundSelectAttr",
                "showType": "text"
            },
            {
                "text": "图片宽度",
                "bindControlAttr": "width",
                "showType": "text",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "图片高度",
                "bindControlAttr": "height",
                "showType": "text",
                "changeExecFunction": "renderContext"
            }
           
            
        ]
    }
]
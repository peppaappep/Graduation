[

    {
        "name": "基础属性",
        "attributes": [{
                "text": "组件标识",
                "bindControlAttr": "caption",
                "showType": "text"
            },
            {
                "text": "名称",
                "bindControlAttr": "label",
                "showType": "text",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "提示文字",
                "bindControlAttr": "placeholder",
                "showType": "text"
            },
            {
                "text": "名称是否显示",
                "bindControlAttr": "showLabel",
                "showType": "boolean"
            },
            {
                "text": "是否可见",
                "showType": "boolean",
                "bindControlAttr": "visible"
            },
			{
			    "text": "取消上下边距",
			    "bindControlAttr": "tbNoPadding",
			    "showType": "boolean"
			},
			{
                "text": "是否有编号按钮",
                "bindControlAttr": "showBtn",
                "showType": "boolean"
            },
			{
			    "text": "自定义编号按钮",
			    "bindControlAttr": "btnIcon",
			    "showType": "text",
				"helper": {
				    "url": "/dsfa/res/dsf_styles/font/demo_index.html",
				    "title": "按钮列表"
				}
			}
        ]
    },
    {
        "name": "高级属性",
        "attributes": [{
                "text": "默认值",
                "bindControlAttr": "metadata.defaultValue",
                "showType": "defaultValue",
                "config": {
                    "value": [
                        { "text": "值", "code": "text", "value": "" }
                    ]
                }
            },
			{
			    "text": "编号规则",
				"bindControlAttr": "rule",
				"showType": "dialog",
				"config": {
				    "url": "/dsfa/pd/views/numeration.html",
				    "width": "500px",
				    "height": "600px",
				    "buttonText": "设置",
				    "title": "设置编号规则"
				}
			},
            {
                "text": "必填标识",
                "bindControlAttr": "$required",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "校验规则",
                "bindControlAttr": "metadata.validate",
                "showType": "validateEditor",
                "changeExecFunction": "renderContext",
                "config": {
                    "url": "/dsfa/pd/views/validateCode.html",
                    "width": "800px",
                    "height": "600px",
                    "buttonText": "设置",
                    "title": "设置"
                }
            },
            {
                "text": "校验错误提示位置",
                "bindControlAttr": "$error_tipsPosition",
                "showType": "select",
                "dictionary": [{
                        "text": "上",
                        "value": "top"
                    }, {
                        "text": "右",
                        "value": "right"
                    },
                    {
                        "text": "下",
                        "value": "bottom"
                    },
                    {
                        "text": "左",
                        "value": "left"
                    }
                ]
                
            },
            {
                "text": "值属性设置",
                "bindControlAttr": "metadata.valueAttributes",
                "showType": "dialog",
                "config": {
                    "url": "/dsfa/pd/views/valueAttributesEdit.html",
                    "width": "600px",
                    "height": "600px",
                    "buttonText": "设置",
                    "title": "设置"
                }
            },
            {
                "text": "是否可以提交",
                "bindControlAttr": "$allowPost",
                "showType": "boolean"
            },
            {
                "text": "是否即时触发审核",
                "bindControlAttr": "$immediatelyAudit",
                "showType": "boolean"
            }
        ]
    }
]
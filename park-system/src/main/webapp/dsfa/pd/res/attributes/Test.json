[

    {
        "name": "基础属性--测试",
        "attributes": [{
                "text": "组件标识",
                "bindControlAttr": "caption",
                "showType": "text"
            },
            {
                "text": "名称",
                "bindControlAttr": "label",
                "showType": "text",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "名称是否显示",
                "bindControlAttr": "showLabel",
                "showType": "boolean"
            },
            {
                "text": "是否只读",
                "showType": "boolean",
                "bindControlAttr": "readOnly"
            },
            {
                "text": "是否失效",
                "showType": "boolean",
                "bindControlAttr": "disabled",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否可见",
                "showType": "boolean",
                "bindControlAttr": "visible",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "数量上限",
                "bindControlAttr": "maxTags",
                "showType": "text",
                "type":"number"
            },
            {
                "text": "显示类型",
                "bindControlAttr": "showType",
                "showType": "select",
                "dictionary": [
                    {
                        "text": "人员",
                        "value": "user"
                    },
                    {
                        "text": "部门",
                        "value": "dept"
                    }
                ]
            },{
                "text": "数据类型",
                "showType": "checkbox",
                "bindControlAttr": "tabs",
                "dictionary": [{
                    "text": "常用",
                    "value": "common",
                    "checked":true
                },{
                    "text": "本部门",
                    "value": "unit"
                },{
                    "text": "小组",
                    "value": "group"
                },{
                    "text": "本单位",
                    "value": "department"
                },{
                    "text": "组织架构",
                    "value": "framework"
                }]
            },
            {
                "text": "是否可排序",
                "bindControlAttr": "canSort",
                "showType": "boolean"
            },
            {
                "text": "可选择的类型值(用逗号分隔)",
                "bindControlAttr": "types",
                "showType": "text"
            }
        ]
    },
    {
        "name": "高级属性",
        "attributes": [
            {
                "text": "弹出窗口标题",
                "bindControlAttr": "$dialogTitle",
                "showType": "text"
            },
            {
                "text": "弹出窗口大小",
                "bindControlAttr": "$dialoSize",
                "showType": "text"
            },
            {
                "text": "默认值",
                "bindControlAttr": "metadata.defaultValue",
                "showType": "defaultValue",
                "config": {
                    "value": [
                        { "text": "文本", "code": "text", "value": "" },
                        { "text": "值", "code": "value", "value": "" }
                    ]
                }
            },
            {
                "text": "校验规则",
                "bindControlAttr": "metadata.validate",
                "showType": "dialog",
                "config": {
                    "url": "/dsfa/pd/views/validateRult.html",
                    "width": "600px",
                    "height": "600px",
                    "buttonText": "设置",
                    "title": "设置"
                }
            },
            {
                "text": "值属性设置",
                "bindControlAttr": "metadata.valueAttributes",
                "showType": "dialog",
                "config": {
                    "url": "/dsfa/pd/views/valueAttributesEdit.html",
                    "width": "600px",
                    "height": "600px",
                    "buttonText": "设置",
                    "title": "设置"
                }
            }   
        ]
    }
]
    {
      "name": "基础属性",
      "attributes": [{
        "text": "组件标识",
        "bindControlAttr": "caption",
        "showType": "text"
      },
        {
          "text": "标题",
          "showType": "text",
          "bindControlAttr": "label"
        },
        {
          "text": "是否只读",
          "showType": "boolean",
          "bindControlAttr": "readOnly"
        },
        {
          "text": "是否显示标题",
          "showType": "boolean",
          "bindControlAttr": "showLabel"
        },
        {
          "text": "是否序号",
          "showType": "boolean",
          "bindControlAttr": "showIndex"
        },
        {
          "text": "是否可见",
          "showType": "boolean",
          "bindControlAttr": "visible",
          "changeExecFunction": "renderContext"
        },
        {
            "text": "首页条数",
            "showType": "number",
            "bindControlAttr": "$pageSize",
            "changeExecFunction": "renderContext"
        }
  
      ]
    }

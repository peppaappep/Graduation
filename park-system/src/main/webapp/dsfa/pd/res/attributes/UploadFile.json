[

    {
        "name": "基础属性",
        "attributes": [
            {
                "text": "组件标识",
                "bindControlAttr": "caption",
                "showType": "text"
            },
            {
                "text": "名称",
                "bindControlAttr": "label",
                "showType": "text",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "名称是否显示",
                "bindControlAttr": "showLabel",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否可见",
                "showType": "boolean",
                "bindControlAttr": "visible",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否只读",
                "showType": "boolean",
                "bindControlAttr": "readOnly",
                "changeExecFunction": "renderContext"
            }
        ]
    }, 
    {
        "name": "控件属性",
        "attributes": [
              {
                "text": "是否开启预览",
                "bindControlAttr": "preview",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "按钮名称是否显示",
                "bindControlAttr": "showBtnName",
                "showType": "boolean",  
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否支持多张上传",
                "bindControlAttr": "$multiple",
                "showType": "boolean",
                "hiddenKeyClass":"fileNum",
                "changeExecFunction": "renderContext"
            },
            {
                "text":"是否开启拖拽",
                "bindControlAttr":"isDragable",
                "showType":"boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "上传文件数量",
                "bindControlAttr": "$uploadFileNum",
                "showType": "text",
                "class":"fileNum",
                "changeExecFunction": "renderContext",
                "hidden":"$multiple==false"
            },
            {
                "text": "上传文件大小",
                "bindControlAttr": "$maxFileSize",
                "showType": "text",
                "changeExecFunction": "renderContext"
            },
			{
			    "text": "文件上传条件设置",
			    "bindControlAttr": "$extsSetting",
				"showType": "dialog",
				"changeExecFunction": "renderContext",
				"config": {
				    "url": "/dsfa/pd/views/uploadFileAttr.html",
				    "width": "800px",
				    "height": "600px",
				    "buttonText": "设置",
				    "title": "设置"
				}
			},
            {
                "text": "文件打包下载文件名称",
                "bindControlAttr": "$zipFileName",
                "showType": "text"
            },
            {
                "text": "文件上传接口",
                "bindControlAttr": "requestUrl",
                "showType": "text",
				"changeExecFunction": "renderContext"
            }

        ]
    },
    {
        "name": "高级属性",
        "attributes": [{
            "text": "元数据",
            "bindControlAttr": "metadata",
            "showType": "mmdata",
            "config": {
                "url": "/dsfa/pd/views/metadataEdit.html",
                "width": "600px",
                "height": "600px",
                "buttonText": "选择元数据",
                "title": "元数据设置"
            }
        }, {
            "text": "必填标识",
            "bindControlAttr": "$required",
            "showType": "boolean",
            "changeExecFunction": "renderContext"
        },
        {
            "text": "校验规则",
            "bindControlAttr": "metadata.validate",
            "showType": "validateEditor",
            "changeExecFunction": "renderContext",
            "config": {
                "url": "/dsfa/pd/views/validateCode.html",
                "width": "800px",
                "height": "600px",
                "buttonText": "设置",
                "title": "设置"
            }
        }]
    }
]
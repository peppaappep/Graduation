[{
        "name": "基础属性",
        "attributes": [{
                "text": "组件标识",
                "bindControlAttr": "caption",
                "showType": "text",
                "isShow": "@[$pageType]!='QIPage'"
            },
            {
                "text": "题目序号",
                "bindControlAttr": "questionIndex",
                "showType": "text",
                "config": {
                    "disabled": true
                }
            },
            {
                "text": "题干",
                "bindControlAttr": "questionBody",
                "showType": "text"
            },
            {
                "text": "最大值",
                "bindControlAttr": "max",
                "showType": "text"
            },
            {
                "text": "最小值",
                "bindControlAttr": "min",
                "showType": "text"
            },
            {
                "text": "步长",
                "bindControlAttr": "step",
                "showType": "text"
            },
            {
                "text": "是否只读",
                "showType": "boolean",
                "bindControlAttr": "readOnly"
            },
            {
                "text": "是否可见",
                "showType": "boolean",
                "bindControlAttr": "visible",
                "changeExecFunction": "renderContext"
            }
        ]
    },
    {
        "name": "高级属性",
        "attributes": [
            {
                "text": "必填标识",
                "bindControlAttr": "$required",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "校验规则",
                "bindControlAttr": "metadata.validate",
                "showType": "validateEditor",
                "changeExecFunction": "renderContext",
                "config": {
                    "url": "/dsfa/pd/views/validateCode.html",
                    "width": "800px",
                    "height": "600px",
                    "buttonText": "设置",
                    "title": "设置"
                }
            }
        ]
    }
]

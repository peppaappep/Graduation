[
    {
        "name": "基础属性",
        "attributes": [
            {
                "text": "组件标识",
                "bindControlAttr": "caption",
                "showType": "text"
            },
            {
                "text": "评论部件名称",
                "bindControlAttr": "$Msgtitle",
                "showType": "text",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否只读",
                "bindControlAttr": "$readOnly",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "按钮颜色值",
                "showType": "text",
                "bindControlAttr": "backgroundColor",
                "changeExecFunction": "setColor"
            },
            {
                "text": "缩进评论数量",
                "bindControlAttr": "$indentNum",
                "showType": "text"
            },
            {
                "text": "业务类型",
                "bindControlAttr": "$businessType",
                "showType": "text"
            },
            {
                "text": "排序方式",
                "bindControlAttr": "$orderWay",
                "showType": "select",
                "dictionary": [
                    {
                        "value": "up",
                        "text": "升序"
                    },
                    {
                        "value": "down",
                        "text": "降序"
                    }
                ]
            },
            {
                "text": " 排序类型",
                "bindControlAttr": "$orderType",
                "showType": "select",
                "dictionary": [
                    {
                        "value": "time",
                        "text": "时间"
                    },
                    {
                        "value": "hot",
                        "text": "热度"
                    }
                ]
            },
            {
                "text": "每页一级评论显示条数",
                "bindControlAttr": "$pageSize",
                "showType": "text"
            },
            {
                "text": "每页子级评论显示条数",
                "bindControlAttr": "$childPageSize",
                "showType": "text"
            },
            {
                "text": "权限请求接口",
                "bindControlAttr": "$source",
                "showType": "text"
            },
            {
                "text": "是否显示分页",
                "bindControlAttr": "$isShowPagination",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "按钮设置",
                "showType": "dialog",
                "bindControlAttr": "$buttonBar",
                "changeExecFunction": "renderContext",
                "config": {
                    "title": "数据列设置",
                    "url": "/dsfa/pd/views/buttonsEdit.html",
                    "width": "1400px",
                    "height": "600px",
                    "buttonText": "设置"
                }
            },
            {
                "text": "是否只查我的",
                "bindControlAttr": "isOwn",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否显示主题",
                "bindControlAttr": "isShowHashTag",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            }
        ]
    },
    {
        "name": "高级属性",
        "attributes": [
            {
                "text": "绑定数据字典",
                "showType": "dialog",
                "bindControlAttr": "$metadata.dataSource",
                "changeExecFunction": "renderContext",
                "config": {
                    "url": "/dsfa/pd/views/enumEditor.html",
                    "width": "850px",
                    "height": "550px",
                    "buttonText": "编辑选项",
                    "title": "编辑选项"
                }
            }
        ]
    }
]

[

  {
    "name": "基础属性",
    "attributes": [{
      "text": "组件标识",
      "bindControlAttr": "caption",
      "showType": "text"
    },
      {
        "text": "名称",
        "bindControlAttr": "label",
        "showType": "text",
        "changeExecFunction": "renderContext"
      },
      {
        "text": "名称是否显示",
        "bindControlAttr": "showLabel",
        "showType": "boolean"
      },
      {
        "text": "选项请求接口",
        "showType": "text",
        "bindControlAttr": "requestUrl"
      },
      {
       
        "text": "联想框是否显示",
        "bindControlAttr": "$isShowRelativeBox",
        "showType": "boolean",
        "hiddenKeyClass":"showBox",
        "showKeyClass":"showBox",
        "changeExecFunction": "renderContext"
      },
      {
        "text":"数据框间距",
        "showType": "text",
        "bindControlAttr": "$distance",
        "changeExecFunction": "renderContext",
        "class":"showBox",
        "hidden":"$isShowRelativeBox==false"
      },
      {
        "text": "关联控件配置",
        "bindControlAttr": "$relativeBoxObj",
        "showType": "dialog",
        "changeExecFunction": "renderContext",
        "config": {
          "url": "/dsfa/pd/views/relativeAttributes.html",
          "width": "600px",
          "height": "600px",
          "buttonText": "设置",
          "title": "设置",
          "value": [
            { "text": "关联控件标识", "code": "caption", "value": "" },
            { "text": "对应查询字段", "code": "value", "value": "" }

          ]
        }
      },
      {
        "text": "是否只读",
        "showType": "boolean",
        "bindControlAttr": "readOnly"
      },
      {
        "text": "是否失效",
        "showType": "boolean",
        "bindControlAttr": "disabled",
        "hiddenKeyClass":"showIcon",
        "showKeyClass":"showIcon",
        "changeExecFunction": "renderContext"
      },
      {
        "text": "方块是否显示删除图标",
        "showType": "boolean",
        "bindControlAttr": "isshowDelIcon",
        "class":"showIcon",
        "hidden":"$isshowDelIcon==false"
      },
      {
        "text": "是否可见",
        "showType": "boolean",
        "bindControlAttr": "visible",
        "changeExecFunction": "renderContext"
      },
      {
        "text": "可选择上限",
        "bindControlAttr": "maxChooseNum",
        "showType": "text",
        "type":"number",
        "changeExecFunction": "renderSelect"
      },
      {
        "text": "提示文字",
        "bindControlAttr": "placeholder",
        "showType": "text"
      },
      {
        "text": "只读状态显示内容",
        "bindControlAttr": "readOnlyShowText",
        "showType": "select",
        "dictionary": [{
          "text": "文本",
          "value": "text"
        }, {
          "text": "值",
          "value": "value"
        }]
      }
    ]
  },
  {
    "name": "高级属性",
    "attributes": [{
      "text": "默认值",
      "bindControlAttr": "metadata.defaultValue",
      "showType": "defaultValue",
      "config": {
        "value": [
          { "text": "文本", "code": "text", "value": "" },
          { "text": "值", "code": "value", "value": "" }
        ]
      }
    },
      {
        "text": "必填标识",
        "bindControlAttr": "$required",
        "showType": "boolean",
        "changeExecFunction": "renderContext"
      },
      {
        "text": "校验规则",
        "bindControlAttr": "metadata.validate",
        "showType": "validateEditor",
        "changeExecFunction": "renderContext",
        "config": {
          "url": "/dsfa/pd/views/validateCode.html",
          "width": "800px",
          "height": "600px",
          "buttonText": "设置",
          "title": "设置"
        }
      },
      {
        "text": "校验错误提示位置",
        "bindControlAttr": "$error_tipsPosition",
        "showType": "select",
        "dictionary": [{
          "text": "上",
          "value": "top"
        }, {
          "text": "右",
          "value": "right"
        },
          {
            "text": "下",
            "value": "bottom"
          },
          {
            "text": "左",
            "value": "left"
          }
        ]

      },
      {
        "text": "值属性设置",
        "bindControlAttr": "metadata.valueAttributes",
        "showType": "dialog",
        "config": {
          "url": "/dsfa/pd/views/valueAttributesEdit.html",
          "width": "600px",
          "height": "600px",
          "buttonText": "设置",
          "title": "设置"
        }
      }
    ]
  }
]

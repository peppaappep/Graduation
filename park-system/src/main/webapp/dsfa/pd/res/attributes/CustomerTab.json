[

    {
        "name": "基础属性",
        "attributes": [{
                "text": "组件标识",
                "bindControlAttr": "caption",
                "showType": "text"
            },
            {
                "text": "是否只读",
                "showType": "boolean",
                "bindControlAttr": "readOnly"
            },
            {
                "text": "是否失效",
                "showType": "boolean",
                "bindControlAttr": "disabled",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否可见",
                "showType": "boolean",
                "bindControlAttr": "visible",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "显示模块个数",
                "showType": "text",
                "bindControlAttr": "tabNum",
                "changeExecFunction": "renderBox"
            },
            {
                "text": "是否循环",
                "showType": "boolean",
                "bindControlAttr": "fullpageOption.continuousVertical"
            },
            {
                "text": "导航位置",
                "showType": "select",
                "bindControlAttr": "fullpageOption.navigationPosition",
                "dictionary": [{
                    "text": "左",
                    "value": "left"
                }, {
                    "text": "右",
                    "value": "right"
                }]
            }
        ]
    },
    {
        "name": "高级属性",
        "attributes": [
      
            {
                "text": "必填标识",
                "bindControlAttr": "$required",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "校验错误提示位置",
                "bindControlAttr": "$error_tipsPosition",
                "showType": "select",
                "dictionary": [{
                        "text": "上",
                        "value": "top"
                    }, {
                        "text": "右",
                        "value": "right"
                    },
                    {
                        "text": "下",
                        "value": "bottom"
                    },
                    {
                        "text": "左",
                        "value": "left"
                    }
                ]
                
            },
            {
                "text": "校验规则",
                "bindControlAttr": "metadata.validate",
                "showType": "validateEditor",
                "changeExecFunction": "renderContext",
                "config": {
                    "url": "/dsfa/pd/views/validateCode.html",
                    "width": "800px",
                    "height": "600px",
                    "buttonText": "设置",
                    "title": "设置"
                }
            },
            {
                "text": "值属性设置",
                "bindControlAttr": "metadata.valueAttributes",
                "showType": "dialog",
                "config": {
                    "url": "/dsfa/pd/views/valueAttributesEdit.html",
                    "width": "600px",
                    "height": "600px",
                    "buttonText": "设置",
                    "title": "设置"
                }
            }
        ]
    }
]
[
  {
    "name": "基础属性",
    "attributes": [
      {
        "text": "组件标识",
        "bindControlAttr": "caption",
        "showType": "text"
      },
      {
        "text": "评论部件名称",
        "bindControlAttr": "$Msgtitle",
        "showType": "text",
        "changeExecFunction": "renderContext"
      },
      {
        "text": "缩进评论数量",
        "bindControlAttr": "$indentNum",
        "showType": "text"
      },
      {
        "text": "业务类型",
        "bindControlAttr": "$businessType",
        "showType": "text"
      },
      {
        "text": "用户类型",
        "bindControlAttr": "$userType",
        "showType": "select",
        "dictionary": [
          {
            "value": "teacher",
            "text": "教师"
          },
          {
            "value": "student",
            "text": "学员"
          }
        ]
      },
      {
        "text": "每页评论显示条数",
        "bindControlAttr": "$limit",
        "showType": "text"
      },
      {
        "text": "权限请求接口",
        "bindControlAttr": "$source",
        "showType": "text"
      },
			{
				"text": "是否显示分页",
				"bindControlAttr": "$isShowPagination",
				"showType": "boolean",
				"changeExecFunction": "renderContext"
			}
    ]
  },
  {
    "name": "高级属性",
    "attributes": [
      
      {
        "text": "绑定数据字典",
        "showType": "dialog",
        "bindControlAttr": "$metadata.dataSource",
        "changeExecFunction": "renderContext",
        "config": {
            "url": "/dsfa/pd/views/enumEditor.html",
            "width": "850px",
            "height": "550px",
            "buttonText": "编辑选项",
            "title": "编辑选项"
        }
      }
    ]
  }
]
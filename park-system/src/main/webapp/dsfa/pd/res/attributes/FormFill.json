[{
        "name": "基础属性",
        "attributes": [{
                "text": "组件标识",
                "bindControlAttr": "caption",
                "showType": "text"
            },
            {
                "text": "名称",
                "bindControlAttr": "label",
                "showType": "text",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "名称是否显示",
                "bindControlAttr": "showLabel",
                "showType": "boolean"
            },
            {
                "text": "题干",
                "bindControlAttr": "questionBody",
                "showType": "text"
            },
            {
                "text": "是否只读",
                "showType": "boolean",
                "bindControlAttr": "readOnly"
            },
            {
                "text": "是否可见",
                "showType": "boolean",
                "bindControlAttr": "visible",
                "changeExecFunction": "renderContext"
            }
        ]
    },
    {
        "name": "高级属性",
        "attributes": [{
                "text": "必填标识",
                "bindControlAttr": "$required",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "校验规则",
                "bindControlAttr": "metadata.validate",
                "showType": "validateEditor",
                "changeExecFunction": "renderContext",
                "config": {
                    "url": "/dsfa/pd/views/validateCode.html",
                    "width": "800px",
                    "height": "600px",
                    "buttonText": "设置",
                    "title": "设置"
                }
            },
            {
                "text": "是否即时触发审核",
                "bindControlAttr": "$immediatelyAudit",
                "showType": "boolean"
            }
        ]
    }
]
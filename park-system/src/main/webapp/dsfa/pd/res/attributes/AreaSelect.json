[
    {
        "name": "基础属性",
        "attributes": [
            {
                "text": "组件标识",
                "bindControlAttr": "caption",
                "showType": "text"
            },
            {
                "text": "名称",
                "bindControlAttr": "label",
                "showType": "text",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "名称是否显示",
                "bindControlAttr": "showLabel",
                "showType": "boolean"
            },
            {
                "text": "是否只读",
                "showType": "boolean",
                "bindControlAttr": "readOnly"
            },
            {
                "text": "是否失效",
                "showType": "boolean",
                "bindControlAttr": "disabled"
            },
            {
                "text": "是否可见",
                "showType": "boolean",
                "bindControlAttr": "visible",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "显示模式",
                "bindControlAttr": "selectBoxClass",
                "showType": "select",
                "changeExecFunction": "changeStyle",
                "dictionary": [
                    {
                        "text": "内联模式",
                        "value": "layui-input-inline"
                    },
                    {
                        "text": "块级模式",
                        "value": "layui-input-block"
                    }
                ]
            },
            {
                "text": "级别选择",
                "showType": "rangeSelect",
                "bindControlAttr": "range",
                "changeExecFunction": "renderContextDisplay",
                "hiddenKeyClass":"superCode",
                "dictionary": [
                    {
                        "text": "省",
                        "value": "0"
                    },
                    {
                        "text": "市",
                        "value": "1"
                    },
                    {
                        "text": "区",
                        "value": "2"
                    },
                    {
                        "text": "街道",
                        "value": "3"
                    },
                    {
                        "text": "村居",
                        "value": "4"
                    }
                ]
            },
            {
                "text": "上级编码",
                "showType": "text",
                "bindControlAttr": "superCode",
                "hidden":"!range[0]",
                "class":"superCode"
            },
			{
			    "text": "固定编码",
			    "showType": "text",
			    "bindControlAttr": "fixedCode"
			},
            {
                "text": "值属性设置",
                "bindControlAttr": "metadata.valueAttributes",
                "showType": "dialog",
                "config": {
                    "url": "/dsfa/pd/views/valueAttributesEdit.html",
                    "width": "600px",
                    "height": "600px",
                    "buttonText": "设置",
                    "title": "设置"
                }
            }
        ]
    },
	{
	    "name": "高级属性",
	    "attributes": [{
			"text": "值属性设置",
			"bindControlAttr": "metadata.valueAttributes",
			"showType": "dialog",
			"config": {
				"url": "/dsfa/pd/views/valueAttributesEdit.html",
				"width": "600px",
				"height": "600px",
				"buttonText": "设置",
				"title": "设置"
			}
		}]
	}
]
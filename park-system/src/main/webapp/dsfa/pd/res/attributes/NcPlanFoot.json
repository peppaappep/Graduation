[
  {
    "name": "基础属性",
    "attributes": [
      {
        "text": "组件标识",
        "bindControlAttr": "caption",
        "showType": "text"
      },
      {
         "text": "显示显示边距",
         "bindControlAttr": "showPadding",
         "showType": "boolean"
     },
      {
        "text": "是否可见",
        "showType": "boolean",
        "bindControlAttr": "visible",
        "changeExecFunction": "renderContext"
      },
      {
        "text": "是否失效",
        "showType": "boolean",
        "bindControlAttr": "disabled",
        "changeExecFunction": "renderContext"
      },
      {
        "text": "背景",
        "bindControlAttr": "gfooterbg",
        "showType": "text",
        "config":{
         "placeholder":"示例（transparent,/res/.../footbg.jpg）"
        }
      },
      {
        "text": "logo图片",
        "bindControlAttr": "$planlogoDate.logosrc",
        "showType": "text",
        "changeExecFunction": "renderContext"
      },
      {
        "text": "logo下的文本",
        "bindControlAttr": "logotext",
        "showType": "text"
      },
      {
        "text": "底部版权",
        "bindControlAttr": "copyright",
        "showType": "text"
      }
    ]
  },
  {
      "name": "高级属性",
      "attributes": [
      	{
         "text": "联系方式列表设置",
         "showType": "dialog",
         "bindControlAttr": "$plantelArr",
         "changeExecFunction": "jsonreset",
         "config": {
            "title": "联系方式列表设置",
            "url": "/dsfa/pd/views/NcPlanFootel.html",
            "width": "1200px",
            "height": "600px",
            "buttonText": "联系方式列表"
         }
      	},
      	{
         "text": "友情链接设置",
         "showType": "dialog",
         "bindControlAttr": "$planlinksArr",
         "changeExecFunction": "jsonreset",
         "config": {
            "title": "友情链接设置",
            "url": "/dsfa/pd/views/NcPlanFootel.html",
            "width": "900px",
            "height": "600px",
            "buttonText": "友情链接"
         }
      	},
      	{
         "text": "合作伙伴链接设置",
         "showType": "dialog",
         "bindControlAttr": "$planaboutArr",
         "changeExecFunction": "jsonreset",
         "config": {
            "title": "合作伙伴链接设置",
            "url": "/dsfa/pd/views/NcPlanFootel.html",
            "width": "900px",
            "height": "600px",
            "buttonText": "合作伙伴"
         }
      	}
      ]
   }
]
[

    {
        "name": "基础属性",
        "attributes": [{
                "text": "组件标识",
                "bindControlAttr": "caption",
                "showType": "text"
            },
            {
                "text": "是否只读",
                "showType": "boolean",
                "bindControlAttr": "readOnly"
            },
            {
                "text": "是否失效",
                "showType": "boolean",
                "bindControlAttr": "disabled",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否可见",
                "showType": "boolean",
                "bindControlAttr": "visible",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "取消上下边距",
                "bindControlAttr": "tbNoPadding",
                "showType": "boolean"
            },
			{
			    "text": "发生击键和执行搜索之间的延迟（以毫秒为单位)",
			    "bindControlAttr": "delay",
			    "showType": "number"
			}
        ]
    },
    {
        "name": "高级属性",
        "attributes": [
      
            {
                "text": "必填标识",
                "bindControlAttr": "$required",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "校验错误提示位置",
                "bindControlAttr": "$error_tipsPosition",
                "showType": "select",
                "dictionary": [{
                        "text": "上",
                        "value": "top"
                    }, {
                        "text": "右",
                        "value": "right"
                    },
                    {
                        "text": "下",
                        "value": "bottom"
                    },
                    {
                        "text": "左",
                        "value": "left"
                    }
                ]
                
            },
            {
                "text": "校验规则",
                "bindControlAttr": "metadata.validate",
                "showType": "validateEditor",
                "changeExecFunction": "renderContext",
                "config": {
                    "url": "/dsfa/pd/views/validateCode.html",
                    "width": "800px",
                    "height": "600px",
                    "buttonText": "设置",
                    "title": "设置"
                }
            },
            {
                "text": "值属性设置",
                "bindControlAttr": "metadata.valueAttributes",
                "showType": "dialog",
                "config": {
                    "url": "/dsfa/pd/views/valueAttributesEdit.html",
                    "width": "600px",
                    "height": "600px",
                    "buttonText": "设置",
                    "title": "设置"
                }
            }
        ]
    }
]
[

    {
        "name": "基础属性",
        "attributes": [{
                "text": "组件标识",
                "bindControlAttr": "caption",
                "showType": "text"
            },
            {
                "text": "背景设置",
                "bindControlAttr": "background",
                "showType": "backgroundEditor"
            },
            {
                "text": "上外边距",
                "bindControlAttr": "$marginTop",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "下外边距",
                "bindControlAttr": "$marginBottom",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "左外边距",
                "bindControlAttr": "$marginLeft",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "右外边距",
                "bindControlAttr": "$marginRight",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "上内边距",
                "bindControlAttr": "$paddingTop",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "下内边距",
                "bindControlAttr": "$paddingBottom",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "左内边距",
                "bindControlAttr": "$paddingLeft",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "右内边距",
                "bindControlAttr": "$paddingRight",
                "showType": "boolean",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "边距尺寸",
                "showType": "select",
                "bindControlAttr": "$marginSize",
                "dictionary":[
                    {"text":"小","value":"small"},
                    {"text":"中","value":"medium"},
                    {"text":"大","value":"big"}
                ],
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否拉伸",
                "bindControlAttr": "$showModel",
                "showType": "select",
                "dictionary":[
                    {"text":"自动","value":"none"},
                    {"text":"拉伸","value":"full"}
                ],
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否有阴影",
                "showType": "boolean",
                "bindControlAttr": "$shadow",
                "changeExecFunction": "renderContext"
            },
            {
                "text": "是否可见",
                "showType": "boolean",
                "bindControlAttr": "visible",
                "changeExecFunction": "renderContext"
            }
        ]
    }
]
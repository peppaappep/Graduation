[

    {
        "name": "基础属性",
        "attributes": [{
                "text": "组件标识",
                "bindControlAttr": "caption",
                "showType": "text"
            },
            {
                "text": "组件高度",
                "bindControlAttr": "tabHeight",
                "showType": "text",
                "changeExecFunction": "resizeHeight"
            },
            {
                "text": "是否可见",
                "showType": "boolean",
                "bindControlAttr": "visible",
                "changeExecFunction": "renderContext"
            }
        ]
    },
    {
        "name":"控件属性",
        "attributes":[{
            "text": "步骤配置",
            "showType": "dialog",
            "bindControlAttr": "tabTitles",
            "changeExecFunction": "renderDom",
            "config": {
                "title": "步骤设置",
                "url": "/dsfa/pd/views/stepsNavEdit.html",
                "width": "900px",
                "height": "600px",
                "buttonText": "设置"
            }
        }]
    },
    {
        "name": "高级属性",
        "attributes": [{
            "text": "元数据",
            "bindControlAttr": "metadata",
            "showType": "mmdata",
            "config": {
                "url": "/dsfa/pd/views/metadataEdit.html",
                "width": "600px",
                "height": "600px",
                "buttonText": "选择元数据",
                "title": "元数据设置"
            }
        }]
    }
]
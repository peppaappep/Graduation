 left;">\r\n                                                <select lay-filter="fontfamily">\r\n                                                    <option value="SimSun" ds-bind:selected="currSelected.font.fontFamily==\'SimSun\'">宋体</option>\r\n                                                    <option value="FangSong" ds-bind:selected="currSelected.font.fontFamily==\'FangSong\'">仿宋</option>\r\n                                                    <option value="KaiTi" ds-bind:selected="currSelected.font.fontFamily==\'KaiTi\'">楷书</option>\r\n                                                    <option value="SimHei" ds-bind:selected="currSelected.font.fontFamily==\'SimHei\'">黑体</option>\r\n                                                    <option value="Microsoft YaHei" ds-bind:selected="currSelected.font.fontFamily==\'Microsoft YaHei\'">微软雅黑</option>\r\n                                                    <option value="YouYuan" ds-bind:selected="currSelected.font.fontFamily==\'YouYuan\'">幼圆</option>  \r\n                                                    <option value="LiSu" ds-bind:selected="currSelected.font.fontFamily==\'LiSu\'">隶书</option>\r\n                                                </select>\r\n                                            </div>\r\n                                        </div>\r\n                                        <div class="layui-form-item">\r\n                                            <label class="layui-form-label" style="width:55px">颜色</label>\r\n                                            <div class="layui-input-block" style="text-align: left;">\r\n                                                <div id="color_text"></div>\r\n                                            </div>\r\n                                        </div>\r\n                                        <div class="layui-form-item" style="line-height:1em">\r\n                                            <label class="layui-form-label" style="width:55px">大小</label>\r\n                                            <div class="layui-input-block" style="text-align: left;padding-top:16px;box-sizing: border-box;">\r\n                                                <div id="fontSize"></div>\r\n                                            </div>\r\n                                            <!-- <div class="layui-input-block" style="text-align: left;">\r\n                                                <input type="text" name="fontsize" required placeholder="" autocomplete="off" class="layui-input" ds-bind:value="getSelectedObject().font.fontSize" ds-on-change="propValueChange(\'font.fontSize\',$event)">\r\n                                            </div> -->\r\n                                        </div>\r\n                                        <div class="layui-form-item" style="line-height:1em">\r\n                                            <label class="layui-form-label" style="width:55px">行间距</label>\r\n                                            <div class="layui-input-block" style="text-align: left;padding-top:16px;box-sizing: border-box;">\r\n                                                <div id="lineHeight"></div>\r\n                                            </div>\r\n                                        </div>\r\n                                        <div class="layui-form-item" style="line-height:1em">\r\n                                            <label class="layui-form-label" style="width:55px">字间距</label>\r\n                                            <div class="layui-input-block" style="text-align: left;padding-top:16px;box-sizing: border-box;">\r\n                                                <div id="letterSpacing"></div>\r\n                                            </div>\r\n                                        </div>\r\n                                        <div class="layui-form-item">\r\n                                            <label class="layui-form-label" style="width:55px">效果</label>\r\n                                            <div class="layui-input-block" style="text-align:left;">\r\n                                                <a title="加粗" class="ds_button ds_button_md" ds-class="{\'ds_button_auxiliary\':!(currSelected.font.bold)}" ds-on-click="propValueChange(\'font.bold\',$event)"><i class="iconfont icon-zitijiacu"></i></a>\r\n                                                <a title="斜体" class="ds_button ds_button_md" style="margin-left:0px" ds-class="{\'ds_button_auxiliary\':!(currSelected.font.italic)}" ds-on-click="propValueChange(\'font.italic\',$event)"><i class="iconfont icon-zitixieti"></i></a>\r\n                                                <a title="下划线" class="ds_button ds_button_md" style="margin-left:0px" ds-class="{\'ds_button_auxiliary\':!(currSelected.font.underline)}" ds-on-click="propValueChange(\'font.underline\',$event)"><i class="iconfont icon-zitixiahuaxian"></i></a>\r\n                                            </div>\r\n                                        </div>\r\n                                        <div class="layui-form-item">\r\n                                            <label class="layui-form-label" style="width:55px">对齐</label>\r\n                                            <div class="layui-input-block" style="text-align:left;">\r\n                                                <a title="左对齐" class="ds_button ds_button_md" ds-class="{\'ds_button_auxiliary\':!(currSelected.font.align==\'left\')}" ds-on-click="propValueChange(\'font.align\',$event,null,\'left\')"><i class="iconfont icon-zuoduiqi"></i></a>\r\n                                                <a title="居中" class="ds_button ds_button_md" style="margin-left:0px" ds-class="{\'ds_button_auxiliary\':!(currSelected.font.align==\'center\')}" ds-on-click="propValueChange(\'font.align\',$event,null,\'center\')"><i class="iconfont icon-juzhongduiqi"></i></a>\r\n                                                <a title="右对齐" class="ds_button ds_button_md" style="margin-left:0px" ds-class="{\'ds_button_auxiliary\':!(currSelected.font.align==\'right\')}" ds-on-click="propValueChange(\'font.align\',$event,null,\'right\')"><i class="iconfont icon-youduiqi"></i></a>\r\n                                            </div>\r\n                                        </div>\r\n                                        <div class="layui-form-item">\r\n                                            <label class="layui-form-label" style="width:55px">内容</label>\r\n                                            <div class="layui-input-block">\r\n                                                <div contenteditable="contenteditable" ds-html="currSelected.text" ds-on-blur="propValueChange(\'text\',$event)" style="overflow-y:auto;line-height:1.2em;padding:3px;outline:none;border:1px solid #e6e6e6;text-align:left;height:100px"></div>\r\n                                            </div>\r\n                                        </div>\r\n                                    </div>\r\n                                </v-element>\r\n                                <!--图标上传-->\r\n                                <v-element ds-if="item.type==\'bgImg\'">\r\n                                    <div class="layui-form layui-fluid" id="imgProps" ds-key="\'i\'" style="width:500px">\r\n                                        <div class="layui-row">\r\n                                            <div class="layui-col-xs10">\r\n                                                <div class="layui-form-item">\r\n                                                    <label class="layui-form-label">URL</label>\r\n                                                    <div class="layui-input-block">\r\n                                                        <input type="text" name="left" autocomplete="off" ds-bind:value="currSelected.image.src" class="layui-input" ds-on-change="propValueChange(\'image.src\',$event)">\r\n                       
            __append('<div class="ds_printing design">\r\n    <div class="desginer_head">\r\n        <div class="desginer_tools">\r\n            <div class="button-bar" ds-key="\'a\'" ds-if="!_isSetttingIndex">\r\n                <a class="ds_button ds_icon_button_text" ds-on-click="saveTemplate">\r\n                    <i class="iconfont icon-baocun"></i>\r\n                    <div>保存</div>\r\n                </a>\r\n                <a class="ds_button ds_icon_button_text" id="uploadBG" ds-on-click="uploadBG">\r\n                    <i class="iconfont icon-tupiantianjia"></i>\r\n                    <div>底图</div>\r\n                </a>\r\n                <a class="ds_button ds_icon_button_text" ds-on-click="layerSort(\'up\')">\r\n                    <i class="iconfont icon-zhiding1"></i>\r\n                    <div>上一层</div>\r\n                </a>\r\n                <a class="ds_button ds_icon_button_text" ds-on-click="layerSort(\'down\')">\r\n                    <i class="iconfont icon-zhidi"></i>\r\n                    <div>下一层</div>\r\n                </a>\r\n                <a class="ds_button ds_icon_button_text" ds-on-click="undo">\r\n                    <i class="iconfont icon-shangyibu1"></i>\r\n                    <div>回退</div>\r\n                </a>\r\n                <!-- <a class="ds_button ds_icon_button_text" ds-on-click="exportImage()">\r\n                    <i class="iconfont icon-shangyibu1"></i>\r\n                    <div>测试导出</div>\r\n                </a> -->\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <div class="desginer_content">\r\n        <div class="desginer_center" ds-style="{\'left\':$leftWidth, \'right\': \'0px\', \'margin-top\': $headHeight + 10 }">\r\n            <div class="edit_range" tabindex="1" ds-on-keydown="panelKeyDownHandler($event)" ds-on-mousewheel="scaleHandler($event)">\r\n                <div class="edit_range_inner" style="margin:auto" ds-style="{\r\n                  \'position\': \'absolute\',\r\n                  \'width\':getScaleNum(_panelSize.width),\r\n                  \'height\':getScaleNum(_panelSize.height),\r\n                  \'top\':_panelSize.move.y,\r\n                  \'left\':_panelSize.move.x\r\n                }">\r\n                    <v-element>\r\n                        <div class="bg" ds-key="\'bgimage\'" style="background-color:#fff" ds-style="{\r\n                            \'width\':_panelSize.width,\r\n                            \'height\':_panelSize.height,\r\n                            \'transform-origin\':\'0px 0px 0px\',\r\n                            \'transform\':\'scale(\'+_panelSize.scale+\')\',\r\n                            \'background-image\':\'url(\'+getBgPath(_backgroundImage.url)+\')\'\r\n                          }"></div>\r\n                        <div class="panel" ds-key="\'panel\'" ds-if="!_isSetttingIndex" ds-style="{\r\n                                \'width\':_panelSize.width,\r\n                                \'height\':_panelSize.height,\r\n                                \'transform-origin\':\'0px 0px 0px\',\r\n                                \'transform\':\'scale(\'+_panelSize.scale+\')\'\r\n                            }" ds-on-mousedown="panelMouseDownHandler">\r\n                            <v-element ds-for="(item,$index) in $objectList">\r\n                                <div ds-if="item.type==\'text\'" ds-bind:sid="item.id" state="0" ds-bind:assist="item.isAssist?0:1" ds-on-dblclick="editObjectText(item,$event)" ds-key="item.id" class="ds_print_object" ds-bind:type="item.type" ds-on-mousedown="[selectedObject(item,$event),moveObjectHandler(item,$event)]" ds-style="{\r\n                                    \'transform\':\'rotate(\' + item.angle + \'deg)\',\r\n                                    \'top\':item.top,\r\n                                    \'left\':item.left,\r\n                                    \'width\':item.width,\r\n                                    \'height\':item.height,\r\n                                    \'line-height\':item.height\r\n                                }">\r\n                                    <div ds-if="!item.editing" class="no-edit" ds-key="\'no-edit\'" style="word-break: break-all;" ds-style="{\r\n                                        \'color\':item.font.color,\r\n                                        \'text-align\':item.font.align,\r\n                                        \'font-family\':item.font.fontFamily,\r\n                                        \'font-size\':item.font.fontSize+\'px\',\r\n                                        \'font-weight\':(item.font.bold?\'bold\':\'normal\'),\r\n                                        \'text-decoration\':(item.font.underline?\'underline\':\'none\'),\r\n                                        \'font-style\':(item.font.italic?\'italic\':\'normal\'),\r\n                                        \'line-height\':item.font.lineHeight+\'em\',\r\n                                        \'letter-spacing\':item.font.letterSpacing+\'px\',\r\n                                        \'text-indent\':getTextIndent(item)+\'px\'\r\n                                    }" ds-html="getTextContent(item)"></div>\r\n                                    <div ds-else class="edit" ds-key="\'edit\'" style="word-break: break-all;" ds-style="{\r\n                                        \'color\':item.font.color,\r\n                                        \'text-align\':item.font.align,\r\n                                        \'font-family\':item.font.fontFamily,\r\n                                        \'font-size\':item.font.fontSize+\'px\',\r\n                                        \'font-weight\':(item.font.bold?\'bold\':\'normal\'),\r\n                                        \'text-decoration\':(item.font.underline?\'underline\':\'none\'),\r\n                                        \'font-style\':(item.font.italic?\'italic\':\'normal\'),\r\n                                        \'line-height\':item.font.lineHeight+\'em\',\r\n                                        \'letter-spacing\':item.font.letterSpacing+\'px\',\r\n                                        \'text-indent\':getTextIndent(item)+\'px\'\r\n                                    }" ds-on-mousedown.stop ds-on-keydown="editObjectTextComplete(item,$event)" ds-on-blur="editObjectTextComplete(item,$event)" contenteditable="contenteditable" ds-html="item.text"></div>\r\n                                </div>\r\n                                <div ds-if="item.type==\'img\'" ds-bind:sid="item.id" state="0" ds-bind:assist="item.isAssist?0:1" ds-key="item.id" class="ds_print_object" ds-bind:type="item.type" ds-on-mousedown="[selectedObject(item,$event),moveObjectHandler(item,$event)]" ds-style="{\r\n                                        \'transform\':\'rotate(\' + item.angle + \'deg)\',\r\n                                        \'top\':item.top,\r\n                                        \'left\':item.left,\r\n                                        \'width\':item.width,\r\n                                        \'height\':item.height,\r\n                                        \'line-height\':item.height\r\n                                    }">\r\n                                    <v-element ds-if="item.image.isExpress">\r\n                                        <img ds-bind:src="getBgPath(\'/res/dsf_styles/themes/img/express.png\')" style="vertical-align:top; width:100%;height:100%" ds-on-mousedown.prevent>\r\n                                    </v-element>\r\n                                    <v-element ds-else>\r\n                                        <img ds-if="getBgPath(item.image.src)" ds-bind:src="getBgPath(item.image.src)" style="vertical-align:top;width:100%;height:100%" ds-on-mousedown.prevent>\r\n                                        <img ds-else ds-bind:src="getBgPath(\'/res/dsf_styles/themes/img/image.png\')" style="vertical-align:top;width:100%;height:100%" ds-on-mousedown.prevent>\r\n                                    </v-element>\r\n\r\n                                </div>\r\n                            </v-element>\r\n                            <!--选中后的编辑框-->\r\n                            <div ds-key="selectedRect" ds-if="_selectedRect.show" class="ds_select_rect" ds-style="{\r\n                                \'transform\':\'rotate(\' +_selectedRect.angle + \'deg)\',\r\n                                \'top\':_selectedRect.top,\r\n                                \'left\':_selectedRect.left,\r\n                                \'width\':_selectedRect.width,\r\n                                \'height\':_selectedRect.height\r\n                            }">\r\n                                <div class="cp" ds-on-mousedown="rotateObjectHandler($event)"></div>\r\n                                <div class="cpline"></div>\r\n                                <div class="t" pos="t" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                                <div class="l" pos="l" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                                <div class="r" pos="r" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                                <div class="b" pos="b" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                                <div class="tl" pos="tl" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                                <div class="tr" pos="tr" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                                <div class="bl" pos="bl" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                                <div class="br" pos="br" ds-on-mousedown="reszieObjectHandler($event)"></div>\r\n                                <div class="info">宽:{{Math.ceil(_selectedRect.width)}};高:{{Math.ceil(_selectedRect.height)}};角度:{{Math.ceil(_selectedRect.angle)}}</div>\r\n                            </div>\r\n                            <!--框选-->\r\n                            <div class="ds_range_selection" ds-key="rangeselection" ds-if="_rangeSelectionRect.show" ds-style="{\r\n                                \'width\':_rangeSelectionRect.width,\r\n                                \'height\':_rangeSelectionRect.height,\r\n                                \'top\':_rangeSelectionRect.top,\r\n                                \'left\':_rangeSelectionRect.left\r\n                            }"></div>\r\n                            <!--水平对齐标线-->\r\n                            <div style="position:absolute;border-style:none;border-top:1px dotted #6EB1EB;width:100%;height:1px" ds-style="{\'top\':_assist.v.top}" ds-if="_moving&&_assist.v.show"></div>\r\n                            <!--竖直对齐标线-->\r\n                            <div style="position:absolute;border-left:1px dotted #6EB1EB;height:100%;" ds-style="{\'left\':_assist.h.left}" ds-if="_moving&&_assist.h.show"></div>\r\n                        </div>\r\n                    </v-element>\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <div class="desginer_left" ds-style="{\'margin-top\': $headHeight, \'width\': $leftWidth }">\r\n            <div class="ds_tools" style="margin:0px;">\r\n                <div lay-accordion lay-filter="seat-object" class="layui-collapse">\r\n                    <div class="layui-colla-item" ds-for="(item,$index) in getObject()">\r\n                        <div class="layui-colla-title">{{item.title}}</div>\r\n                        <div class="layui-colla-content layui-show" ds-class="$index==1">\r\n                            <div ds-for="(obj,$index) in item.items" class="ds_tool_item" ds-on-mousedown="initToolsDrag(obj,$event)">{{obj.text}}</div>\r\n                            <div style="clear:both;"></div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <div class="desginer_props" ds-style="{\'margin-top\': $headHeight}">\r\n            <dl>\r\n                <v-element ds-for="(item,$index) in _props" ds-if="item.has(item,currSelected)">\r\n                    <dd ds-if="item.clickType==\'showWindow\'" ds-bind:title="item.text" ds-key="item.text" ds-on-click="propWindowShow(item)">\r\n                        <i class="iconfont" ds-class="item.icon"></i>\r\n                        <div class="propswindow" id="propswindow" ds-if="item.show&&currSelected.id">\r\n                            <div class="propswindow_title">\r\n                                {{item.text}}\r\n                                <i class="iconfont icon-right" ds-on-click.stop="propWindowClose(item)"></i>\r\n                            </div>\r\n                            <div class="propswindow_content" style="overflow:auto;">\r\n                                <v-element ds-if="item.type==\'size\'">\r\n                                    <!--度量-->\r\n                                    <div class="layui-form layui-fluid" id="sizeProps" style="width:450px">\r\n                                        <div class="layui-row">\r\n                                            <div class="layui-col-xs6">\r\n                                                <div class="layui-form-item">\r\n                                                    <label class="layui-form-label" style="width:55px">X</label>\r\n                                                    <div class="layui-input-inline" style="width:80px">\r\n                                                        <input type="text" name="left" autocomplete="off" ds-bind:value="currSelected.left" class="layui-input" ds-on-change="propValueChange(\'left\',$event)">\r\n                                                    </div>\r\n                                                </div>\r\n                                            </div>\r\n                                            <div class="layui-col-xs6">\r\n                                                <div class="layui-form-item">\r\n                                                    <label class="layui-form-label" style="width:55px">Y</label>\r\n                                                    <div class="layui-input-inline" style="width:80px">\r\n                                                        <input type="text" name="top" autocomplete="off" ds-bind:value="currSelected.top" class="layui-input" ds-on-change="propValueChange(\'top\',$event)">\r\n                                                    </div>\r\n                                                </div>\r\n                                            </div>\r\n                                        </div>\r\n                                        <div class="layui-row">\r\n                                            <div class="layui-col-xs6">\r\n                                                <div class="layui-form-item">\r\n                                                    <label class="layui-form-label" style="width:55px">宽</label>\r\n                                                    <div class="layui-input-inline" style="width:80px">\r\n                                                        <input type="text" name="width" autocomplete="off" ds-bind:value="currSelected.width" class="layui-input" ds-on-change="propValueChange(\'width\',$event)">\r\n                                                    </div>\r\n                                                </div>\r\n                                            </div>\r\n                                            <div class="layui-col-xs6">\r\n                                                <div class="layui-form-item">\r\n                                                    <label class="layui-form-label" style="width:55px">高</label>\r\n                                                    <div class="layui-input-inline" style="width:80px">\r\n                                                        <input
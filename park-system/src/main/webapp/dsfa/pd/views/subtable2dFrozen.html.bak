<!DOCTYPE html>
<html lang="en" ng-app="myApp">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>宾栏</title>
    <link rel="stylesheet" type="text/css" href="../../../res/libs/layui/css/layui.css" />
    <link rel="stylesheet" type="text/css" href="../../../res/dsf_styles/dsf_style.css" />
    <link rel="stylesheet" type="text/css" href="../../../res/dsf_styles/font/iconfont.css" />
    <link rel="stylesheet" type="text/css" href="../res/bootstrap.min.css" />
    <link rel="stylesheet" type="text/css" href="../res/components.css" />
    <link rel="stylesheet" type="text/css" href="../../../res/libs/zTree/css/zTreeStyle/zTreeStyle.css" />
    <style>
        .error {
            border: 1px solid red;
        }
    </style>
</head>

<body ng-controller="subTableColumnEdit">
    <div class="container-fluid" style="position: absolute;top:0px;left:0px;right:0px;bottom:0px">
        <div class="row" style="height:100%">
            <div class="col-xs-3" style="height:100%">
                <div style="position: absolute;top:0px;width:100%;">
                    <div style="padding:5px;text-align:left">
                        <a class="ds_button ds_button_md" ng-click="add()">增&nbsp;&nbsp;加</a>
                        <a class="ds_button ds_button_md ds_button_auxiliary" ng-click="deleted()">删&nbsp;&nbsp;除</a>
                    </div>
                </div>
                <div style="position: absolute;bottom:0px;width:100%;top:40px">
                    <ul id="tree" class="ztree"></ul>
                </div>
            </div>
            <div class="col-xs-9" style="height:100%;padding-top:5px;">
                <div class="layui-form" ng-if="current.type!='0'">
                    <div class="layui-form-item layui-form-text">
                        <label class="layui-form-label">名称</label>
                        <div class="layui-input-block">
                            <input type="text" class="layui-input" ng-model="current.name" />
                        </div>
                    </div>
                    <div class="layui-form-item layui-form-text">
                        <label class="layui-form-label">内容</label>
                        <div class="layui-input-block">
                            <textarea class="layui-textarea" placeholder="请输入" ng-model="current.text"></textarea>
                        </div>
                    </div>
                    <div class="layui-form-item layui-form-text">
                        <label class="layui-form-label">类型</label>
                        <div class="layui-input-block">
                            <select ng-model="current.type" lay-filter="type">
                                <option value="1">段落</option>
                                <option value="2">项</option>
                            </select>
                        </div>
                    </div>
                    <div class="layui-form-item layui-form-text">
                        <label class="layui-form-label">无内容填充</label>
                        <div class="layui-input-block">
                            <input type="text" class="layui-input" ng-model="current.fullText" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="../../../res/libs/jquery-1.12.4.min.js"></script>
    <script src="../../../res/libs/layui/layui.all.js"></script>
    <script src="../../../res/libs/zTree/js/jquery.ztree.all.min.js"></script>
    <script src="../../../res/libs/lodash/lodash.min.js"></script>
    <script src="../../../app.js"></script>
    <script src="../../../res/dsf_res/dsf_config.js"></script>
    <script src="../../../res/dsf_res/dsf_common.js"></script>
    <script src="../res/libs/bootstrap.js"></script>
    <link rel="stylesheet" type="text/css" href="../res/components.css" />
    <script src="../res/libs/angular/angular.min.js"></script>
    <script>
        var app = angular.module('myApp', []);
        var dialogArgs = {},
            tempMap = {},
            tree = null;
        app.controller('subTableColumnEdit', function($scope) {
            $scope.args = null;
            $scope.list = [];
            $scope.current = {};
            window.dialogInit = function(args) {
                console.log(args);
                $scope.args = $.extend(true, {}, args);
                initTree();
                layui.form.render();
                layui.form.on("select(type)", function(data) {
                    $scope.current.type = data.value;
                });
            }

            $scope.add = function() {
                let id = dsf.uuid();
                let obj = {
                    "id": id,
                    "type": "1",
                    "text": "",
                    "name":"新建栏",
                    "fullText": "--"
                };
                let nodes = tree.getSelectedNodes();
                let parent = nodes[0];
                parent.children.push({
                    "name": obj.name,
                    "id": id,
                    "children": [],
                    "attr": obj
                });
                $scope.current = obj;
                tree.expandNode(parent, true, false);
                tree.refresh();
                let n = tree.getNodeByParam("id", id);
                selectNode(n);
                layui.form.render();
            }

            $scope.deleted = function() {
                let nodes = tree.getSelectedNodes();
                let currentNode = nodes[0]
                let parent = currentNode.getParentNode();
                let result = _.findIndex(parent.children, function(o) {
                    return o.id == currentNode.id
                });
                if (result != -1) {
                    parent.children.splice(result, 1);
                }
                tree.refresh();
                selectNode(parent);
                // tree.expandNode(parent, true, false);
            }
            $scope.$watch('current.name', function(newValue, oldValue) {
                if (newValue === oldValue) {
                    return;
                }
                if ($scope.current.type != "0") {
                    let id = $scope.current.id;
                    let n = tree.getNodeByParam("id", id);
                    n.name = newValue;
                    tree.updateNode(n);
                }

            });
            window.getDialogResult = function() {
                return $scope.args.value;
            }

            function selectNode(node) {
                tree.selectNode(node);
                let dindex = dsf.layer.loadding();
                $$apply($scope, function() {
                    $scope.current = node.attr;
                    $("select[lay-filter=type]").val($scope.current.type);
                    window.setTimeout(function() {
                        layui.form.render();
                        dsf.layer.close(dindex)
                    }, 500)
                });
            }

            function zTreeOnClick(evt, id, node) {
                selectNode(node)
            }

            function initTree() {
                tree = $.fn.zTree.init($("#tree"), {
                    "view": {
                        "selectedMulti": false
                    },
                    "check": {
                        "enable": false
                    },
                    "callback": {
                        "onClick": zTreeOnClick
                    }
                });
                let rootnode = {
                    "id": "0",
                    "name": "主栏",
                    "children": [],
                    "attr": {
                        "id": "0",
                        "type": "0",
                        "name":"主栏"
                    }
                }
                tree.addNodes(null, [rootnode]);
                let nodes = tree.getNodes();
                tree.selectNode(nodes[0]);
                selectNode(nodes[0]);
            }
        });


        function $$apply(scope, callback) {
            if (!scope.$root.$$phase) {
                if (callback) {
                    scope.$apply(function() {
                        callback ? callback() : dsf.noop();
                    });
                } else {
                    scope.$apply();
                }
            } else {
                callback ? callback() : dsf.noop();
            }
        }
    </script>
</body>

</html>